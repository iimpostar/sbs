<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Sbs" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>

        <item name="colorSecondary">@color/ig_blue</item>
        <item name="colorSecondaryVariant">@color/ig_blue</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">?attr/screenBackground</item>

        <!-- Global screen colors -->
        <item name="screenBackground">@color/black</item>
        <item name="toolbarBackground">@android:color/transparent</item>
        <item name="primaryTextColor">@color/white</item>
        <item name="secondaryTextColor">#B3FFFFFF</item>
        <item name="dividerColor">#26FFFFFF</item>
        <item name="iconTintColor">@color/white</item>
        <item name="previewSurfaceColor">#121212</item>

        <!-- Drawer/menu -->
        <item name="menuBackground">@color/black</item>
        <item name="menuTextColor">@color/white</item>
        <item name="menuSecondaryTextColor">#B3FFFFFF</item>
        <item name="menuIconTint">@color/white</item>
        <item name="menuDividerColor">#26FFFFFF</item>
    </style>

    <style name="DashboardMenuItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:paddingBottom">16dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <style name="DashboardMenuIcon">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:layout_alignParentStart">true</item>
        <item name="android:tint">?attr/menuIconTint</item>
        <item name="android:alpha">0.92</item>
    </style>

    <style name="DashboardMenuText">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_centerVertical">true</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:textColor">?attr/menuTextColor</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="DashboardUserName">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginBottom">24dp</item>
        <item name="android:textColor">?attr/menuSecondaryTextColor</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CircularAvatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>