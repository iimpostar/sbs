<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Sbs" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sbs_button_primary_bg</item>
        <item name="colorPrimaryVariant">@color/sbs_button_primary_bg</item>
        <item name="colorOnPrimary">@color/sbs_button_primary_text</item>

        <item name="colorSecondary">@color/ig_blue</item>
        <item name="colorSecondaryVariant">@color/ig_blue</item>
        <item name="colorOnSecondary">@color/sbs_button_primary_text</item>

        <item name="android:colorBackground">@color/sbs_screen</item>
        <item name="colorOnBackground">@color/sbs_text_primary</item>
        <item name="colorSurface">@color/sbs_surface</item>
        <item name="colorOnSurface">@color/sbs_text_primary</item>
        <item name="colorControlNormal">@color/sbs_input_stroke</item>
        <item name="colorControlActivated">@color/ig_blue</item>
        <item name="colorControlHighlight">@color/ig_blue</item>
        <item name="android:textColorHint">@color/sbs_text_hint</item>

        <item name="android:statusBarColor">@color/sbs_toolbar_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowBackground">?attr/screenBackground</item>

        <!-- Global screen colors -->
        <item name="screenBackground">@color/sbs_screen</item>
        <item name="surfaceBackground">@color/sbs_surface</item>
        <item name="toolbarBackground">@color/sbs_toolbar_bg</item>
        <item name="primaryTextColor">@color/sbs_text_primary</item>
        <item name="secondaryTextColor">@color/sbs_text_secondary</item>
        <item name="hintTextColor">@color/sbs_text_hint</item>
        <item name="dividerColor">@color/sbs_divider</item>
        <item name="iconTintColor">@color/sbs_icon</item>
        <item name="previewSurfaceColor">@color/sbs_preview_surface</item>
        <item name="inputBackground">@color/sbs_input</item>
        <item name="inputStrokeColor">@color/sbs_input_stroke</item>
        <item name="buttonPrimaryBackground">@color/sbs_button_primary_bg</item>
        <item name="buttonPrimaryText">@color/sbs_button_primary_text</item>
        <item name="buttonSecondaryBackground">@color/sbs_button_secondary_bg</item>
        <item name="buttonSecondaryText">@color/sbs_button_secondary_text</item>
        <item name="avatarPlaceholderColor">@color/sbs_avatar_placeholder</item>

        <!-- Drawer/menu -->
        <item name="menuBackground">@color/sbs_surface</item>
        <item name="menuTextColor">@color/sbs_text_primary</item>
        <item name="menuSecondaryTextColor">@color/sbs_text_secondary</item>
        <item name="menuIconTint">@color/sbs_icon</item>
        <item name="menuDividerColor">@color/sbs_divider</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CircularAvatar" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
