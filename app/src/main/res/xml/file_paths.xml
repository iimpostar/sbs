<?xml version="1.0" encoding="utf-8"?>
<!--
    res/xml/file_paths.xml
    ──────────────────────
    Tells FileProvider which directories it is allowed to share URIs for.

    <external-files-path> maps to Context.getExternalFilesDir(), which is:
        /sdcard/Android/data/com.sbs/files/Pictures/

    This is the external files Pictures directory for future media capture.
-->
<paths>
    <external-files-path
        name="camera_images"
        path="Pictures/" />
</paths>
